# =============================
# CineMatch - .gitignore
# =============================

# Python
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/

# Environment — never commit secrets
.env

# DVC managed files — tracked via .dvc files
/data/tmdb_5000_movies.csv
/data/tmdb_5000_credits.csv

# DVC managed model outputs — tracked via dvc.yaml
ml_pipeline/model/

# Feature store — DVC tracked
ml_pipeline/feature_store/

# MLflow runs
mlruns/
ml_pipeline/mlruns/
mlflow.db

# Logs — runtime generated, not needed in Git
logs/
backend/logs/
backend_logs/
frontend_logs/
*.log

# Feedback logs — runtime generated
feedback_logs/

# Airflow database — runtime generated
airflow_db/

# Test cache
.pytest_cache/
.coverage
htmlcov/

# OS
.DS_Store
**/.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/

# __pycache__/
**/__pycache__/
